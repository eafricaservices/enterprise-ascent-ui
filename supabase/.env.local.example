# Supabase Edge Function — local development secrets
# Copy this file to supabase/.env.local (git-ignored) and fill in your values.
# These vars are injected when running:
#   supabase functions serve parse-and-score-cv --env-file supabase/.env.local
#
# In production, set these via:
#   supabase secrets set GROK_API_KEY=your_key_here

# Automatically provided by the Supabase runtime — set here for local dev only
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# xAI Grok API key — obtain from https://console.x.ai/
GROK_API_KEY=xai-<your-key-here>

# Resend API key — obtain from https://resend.com/api-keys
# Used to send CV score notification emails to applicants.
RESEND_API_KEY=re_<your-key-here>
